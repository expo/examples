{
  "expo": {
    "orientation": "default",
    "scheme": "acme",
    "userInterfaceStyle": "light",
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "server"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-image",
      "expo-router",
      "expo-splash-screen",
      "expo-status-bar"
    ]
  }
}
